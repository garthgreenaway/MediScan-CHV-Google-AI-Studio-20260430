rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Assessment validation
    function isValidAssessment(data) {
      return data.size() == 11
        && data.userId == request.auth.uid
        && data.childAge is number
        && data.childTemp is number
        && data.duration is number
        && data.symptoms is string && data.symptoms.size() <= 2000
        && data.location is string && data.location.size() <= 100
        && data.riskLevel in ['Low', 'Medium', 'High']
        && data.likelyCondition is string && data.likelyCondition.size() <= 200
        && data.immediateAction is string && data.immediateAction.size() <= 500
        && data.alertDistrict is bool
        && data.createdAt == request.time;
    }

    // Scan validation
    function isValidScan(data) {
      return data.size() == 5
        && data.userId == request.auth.uid
        && data.muacEstimate is number
        && data.wastingSigns is bool
        && data.confidence in ['High', 'Medium', 'Low']
        && data.createdAt == request.time;
    }

    match /assessments/{assessmentId} {
      allow create: if isSignedIn() && isValidAssessment(request.resource.data);
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // No updates or deletes for assessment history integrity
    }

    match /scans/{scanId} {
      allow create: if isSignedIn() && isValidScan(request.resource.data);
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
